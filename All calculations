def calculate_workout_summary(workouts: List[Workout]) -> WorkoutSummary:
    """Calculate summary statistics for workouts."""
    if not workouts:
        return WorkoutSummary(
            total_workouts=0,
            total_duration_min=0,
            total_calories=0,
            workouts_by_type={},
            avg_duration=0
        )
    
    total_duration = sum(w.duration_min for w in workouts)
    total_calories = sum(w.calories_burned or 0 for w in workouts)
    
    # Count by type
    by_type: dict = defaultdict(int)
    for w in workouts:
        by_type[w.workout_type.value] += 1
    
    return WorkoutSummary(
        total_workouts=len(workouts),
        total_duration_min=total_duration,
        total_calories=round(total_calories, 1),
        workouts_by_type=dict(by_type),
        avg_duration=round(total_duration / len(workouts), 1)
    )


def calculate_workout_score(workouts: List[Workout], period_days: int = 7) -> int:
    """
    Calculate workout health score (0-100).
    
    Based on:
    - Frequency (60%): Target 5 workouts per week
    - Duration (40%): Target 30-45 min average
    """
    if not workouts:
        return 0
    
    # Frequency score (target: 5 per week)
    workouts_per_week = (len(workouts) / period_days) * 7
    frequency_score = min(100, (workouts_per_week / 5) * 100)
    
    # Duration score (optimal: 30-45 min)
    avg_duration = mean(w.duration_min for w in workouts)
    if avg_duration < 15:
        duration_score = 30
    elif avg_duration < 30:
        duration_score = 60
    elif 30 <= avg_duration <= 60:
        duration_score = 100
    elif avg_duration <= 90:
        duration_score = 85
    else:
        duration_score = 70  # Very long workouts
    
    total_score = (frequency_score * 0.6) + (duration_score * 0.4)
    return round(min(100, max(0, total_score)))


def estimate_calories_burned(
    workout_type: str,
    duration_min: int,
    weight_kg: float = 70.0
) -> float:
    """
    Estimate calories burned based on workout type and duration.
    Uses MET (Metabolic Equivalent of Task) values.
    
    Calories = MET * weight_kg * duration_hours
    """
    # MET values for different activities
    met_values = {
        "Cardio": 7.0,
        "Strength": 5.0,
        "HIIT": 8.0,
        "Yoga": 3.0,
        "Swimming": 6.0,
        "Cycling": 7.5,
        "Running": 9.8,
        "Walking": 3.5,
        "Other": 5.0,
    }
    
    met = met_values.get(workout_type, 5.0)
    duration_hours = duration_min / 60
    calories = met * weight_kg * duration_hours
    
    return round(calories, 1)


