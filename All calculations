def categorize_blood_pressure(systolic: int, diastolic: int) -> BPCategory:
    """
    Categorize blood pressure based on American Heart Association guidelines.
    
    Categories:
    - Normal: systolic < 120 AND diastolic < 80
    - Elevated: systolic 120-129 AND diastolic < 80
    - Hypertension Stage 1: systolic 130-139 OR diastolic 80-89
    - Hypertension Stage 2: systolic >= 140 OR diastolic >= 90
    - Hypertensive Crisis: systolic > 180 OR diastolic > 120
    - Low (Hypotension): systolic < 90 OR diastolic < 60
    """
    # Check for crisis first (most urgent)
    if systolic > 180 or diastolic > 120:
        return BPCategory.HYPERTENSIVE_CRISIS
    
    # Check for low blood pressure
    if systolic < 90 or diastolic < 60:
        return BPCategory.LOW
    
    # Check stages from most severe to normal
    if systolic >= 140 or diastolic >= 90:
        return BPCategory.HYPERTENSION_STAGE_2
    
    if systolic >= 130 or diastolic >= 80:
        return BPCategory.HYPERTENSION_STAGE_1
    
    if systolic >= 120 and diastolic < 80:
        return BPCategory.ELEVATED
    
    return BPCategory.NORMAL


def calculate_mean_arterial_pressure(systolic: int, diastolic: int) -> float:
    """
    Calculate Mean Arterial Pressure (MAP).
    
    MAP = Diastolic + (1/3 * Pulse Pressure)
    MAP = Diastolic + (1/3 * (Systolic - Diastolic))
    
    Normal MAP range: 70-100 mmHg
    """
    pulse_pressure = systolic - diastolic
    map_value = diastolic + (pulse_pressure / 3)
    return round(map_value, 1)


def calculate_pulse_pressure(systolic: int, diastolic: int) -> int:
    """
    Calculate Pulse Pressure.
    
    Pulse Pressure = Systolic - Diastolic
    Normal range: 40-60 mmHg
    High pulse pressure (>60) may indicate arterial stiffness
    """
    return systolic - diastolic


def analyze_bp_reading(log: BloodPressureLog) -> BloodPressureReading:
    """Convert a BP log to an analyzed reading with calculated fields."""
    return BloodPressureReading(
        bp_id=log.bp_id,
        systolic=log.systolic,
        diastolic=log.diastolic,
        heart_rate=log.heart_rate,
        recorded_at=log.recorded_at,
        category=categorize_blood_pressure(log.systolic, log.diastolic),
        mean_arterial_pressure=calculate_mean_arterial_pressure(log.systolic, log.diastolic),
        pulse_pressure=calculate_pulse_pressure(log.systolic, log.diastolic),
        notes=log.notes
    )


def calculate_bp_trend(readings: List[BloodPressureLog], days: int = 7) -> str:
    """
    Analyze BP trend over specified period.
    
    Returns: "improving", "stable", or "worsening"
    """
    if len(readings) < 2:
        return "stable"
    
    # Sort by date (newest first)
    sorted_readings = sorted(readings, key=lambda x: x.recorded_at, reverse=True)
    
    # Split into recent half and older half
    mid = len(sorted_readings) // 2
    recent = sorted_readings[:mid] if mid > 0 else sorted_readings[:1]
    older = sorted_readings[mid:] if mid > 0 else sorted_readings[1:]
    
    if not older:
        return "stable"
    
    # Calculate average systolic for each period
    recent_avg = mean(r.systolic for r in recent)
    older_avg = mean(r.systolic for r in older)
    
    # Determine trend (5 mmHg threshold for significance)
    diff = recent_avg - older_avg
    
    if diff < -5:
        return "improving"
    elif diff > 5:
        return "worsening"
    else:
        return "stable"


def calculate_bp_summary(readings: List[BloodPressureLog]) -> BPSummary:
    """Calculate summary statistics for blood pressure readings."""
    if not readings:
        return BPSummary(
            avg_systolic=0,
            avg_diastolic=0,
            avg_heart_rate=None,
            latest_reading=None,
            trend="stable",
            readings_count=0
        )
    
    avg_sys = mean(r.systolic for r in readings)
    avg_dia = mean(r.diastolic for r in readings)
    
    # Heart rate average (only if available)
    hr_readings = [r.heart_rate for r in readings if r.heart_rate is not None]
    avg_hr = mean(hr_readings) if hr_readings else None
    
    # Latest reading
    sorted_readings = sorted(readings, key=lambda x: x.recorded_at, reverse=True)
    latest = analyze_bp_reading(sorted_readings[0])
    
    return BPSummary(
        avg_systolic=round(avg_sys, 1),
        avg_diastolic=round(avg_dia, 1),
        avg_heart_rate=round(avg_hr, 1) if avg_hr else None,
        latest_reading=latest,
        trend=calculate_bp_trend(readings),
        readings_count=len(readings)
    )


def get_bp_health_score(readings: List[BloodPressureLog]) -> int:
    """
    Calculate a health score (0-100) based on BP readings.
    
    Scoring:
    - Normal: 100 points
    - Elevated: 75 points
    - Stage 1: 50 points
    - Stage 2: 25 points
    - Crisis: 0 points
    """
    if not readings:
        return 50  # Neutral score if no data
    
    category_scores = {
        BPCategory.NORMAL: 100,
        BPCategory.ELEVATED: 75,
        BPCategory.HYPERTENSION_STAGE_1: 50,
        BPCategory.HYPERTENSION_STAGE_2: 25,
        BPCategory.HYPERTENSIVE_CRISIS: 0,
        BPCategory.LOW: 60,  # Low BP is concerning but less so
    }
    
    scores = []
    for reading in readings:
        category = categorize_blood_pressure(reading.systolic, reading.diastolic)
        scores.append(category_scores[category])
    
    return round(mean(scores))


