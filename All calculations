def calculate_wellness_scores(
    sleep_logs: List[SleepLog],
    workouts: List[Workout],
    nutrition_logs: List[NutritionLog],
    period_days: int = 7
) -> WellnessScores:
    """
    Calculate comprehensive wellness scores including dopamine and cortisol levels.
    
    Dopamine (Green - Positive Wellness):
    - High when meeting sleep, exercise, and nutrition goals
    - Represents reward, motivation, and positive habits
    
    Cortisol (Red - Stress Indicator):
    - High when NOT meeting goals
    - Represents stress, poor recovery, and health risks
    """
    # Individual scores
    sleep_score = calculate_sleep_score(sleep_logs)
    workout_score = calculate_workout_score(workouts, period_days)
    nutrition_score = calculate_nutrition_score(nutrition_logs)
    
    # Detailed metrics
    sleep_analyses = [analyze_sleep_log(log) for log in sleep_logs] if sleep_logs else []
    avg_sleep_hours = mean(a.duration_hours for a in sleep_analyses) if sleep_analyses else 0
    
    quality_logs = [a.sleep_quality for a in sleep_analyses if a.sleep_quality is not None]
    avg_sleep_quality = mean(quality_logs) if quality_logs else 0
    
    workout_days = len(workouts)
    avg_workout_duration = round(mean(w.duration_min for w in workouts)) if workouts else 0
    
    avg_meals = mean(log.meals for log in nutrition_logs) if nutrition_logs else 0
    avg_water = mean(log.water_glasses for log in nutrition_logs) if nutrition_logs else 0
    
    # DOPAMINE LEVEL (positive wellness)
    # Weighted combination: Sleep 35%, Workout 35%, Nutrition 30%
    dopamine_level = round(
        (sleep_score * 0.35) + 
        (workout_score * 0.35) + 
        (nutrition_score * 0.30)
    )
    
    # CORTISOL LEVEL (stress/negative)
    # Inverse relationship - high when wellness is low
    # But not a simple inverse - stress compounds when multiple areas are poor
    
    # Penalty multipliers for poor scores
    sleep_penalty = max(0, (60 - sleep_score) / 60) if sleep_score < 60 else 0
    workout_penalty = max(0, (50 - workout_score) / 50) if workout_score < 50 else 0
    nutrition_penalty = max(0, (50 - nutrition_score) / 50) if nutrition_score < 50 else 0
    
    # Base cortisol from inverse of wellness
    base_cortisol = 100 - dopamine_level
    
    # Compound penalty when multiple areas are poor
    penalty_count = sum([sleep_penalty > 0, workout_penalty > 0, nutrition_penalty > 0])
    compound_multiplier = 1 + (penalty_count * 0.1)  # 10% increase per poor area
    
    cortisol_level = round(min(100, base_cortisol * compound_multiplier))
    
    return WellnessScores(
        sleep_score=sleep_score,
        workout_score=workout_score,
        nutrition_score=nutrition_score,
        dopamine_level=dopamine_level,
        cortisol_level=cortisol_level,
        avg_sleep_hours=round(avg_sleep_hours, 1),
        avg_sleep_quality=round(avg_sleep_quality, 1),
        workout_days=workout_days,
        avg_workout_duration=avg_workout_duration,
        avg_meals_per_day=round(avg_meals, 1),
        avg_water_intake=round(avg_water, 1)
    )


def calculate_daily_wellness(
    date_val: date,
    sleep_log: Optional[SleepLog],
    workouts: List[Workout],
    nutrition_log: Optional[NutritionLog]
) -> DailyWellnessEntry:
    """Calculate wellness metrics for a single day."""
    
    # Sleep
    if sleep_log:
        analysis = analyze_sleep_log(sleep_log)
        sleep_hours = analysis.duration_hours
        sleep_quality = sleep_log.sleep_quality or 5
    else:
        sleep_hours = 0
        sleep_quality = 0
    
    # Workout
    workout_minutes = sum(w.duration_min for w in workouts)
    
    # Nutrition
    if nutrition_log:
        meals = nutrition_log.meals
        water = nutrition_log.water_glasses
    else:
        meals = 0
        water = 0
    
    # Daily scores
    sleep_score = 100 if 7 <= sleep_hours <= 9 else max(0, 100 - abs(8 - sleep_hours) * 15)
    sleep_score = (sleep_score + (sleep_quality * 10)) / 2
    
    workout_score = min(100, (workout_minutes / 45) * 100) if workout_minutes > 0 else 0
    
    nutrition_score = ((meals / 3) * 50 + (water / 8) * 50)
    nutrition_score = min(100, nutrition_score)
    
    # Daily dopamine and cortisol
    dopamine = round((sleep_score * 0.35) + (workout_score * 0.35) + (nutrition_score * 0.30))
    cortisol = round(100 - dopamine)
    
    # Compound stress if multiple areas are failing
    failures = sum([sleep_hours < 6, workout_minutes == 0, meals < 2])
    if failures >= 2:
        cortisol = min(100, cortisol + 15)
        dopamine = max(0, dopamine - 10)
    
    return DailyWellnessEntry(
        date=date_val,
        dopamine=dopamine,
        cortisol=cortisol,
        sleep_hours=sleep_hours,
        workout_minutes=workout_minutes,
        meals=meals,
        water_glasses=water
    )


def get_wellness_status(scores: WellnessScores) -> str:
    """
    Determine overall wellness status based on scores.
    
    Returns: "Thriving", "Good", "Needs Attention", or "At Risk"
    """
    avg_score = (scores.sleep_score + scores.workout_score + scores.nutrition_score) / 3
    
    if avg_score >= 80 and scores.cortisol_level < 30:
        return "Thriving"
    elif avg_score >= 60 and scores.cortisol_level < 50:
        return "Good"
    elif avg_score >= 40 or scores.cortisol_level < 70:
        return "Needs Attention"
    else:
        return "At Risk"


def generate_wellness_recommendations(scores: WellnessScores) -> List[str]:
    """Generate personalized recommendations based on wellness scores."""
    recommendations = []
    
    # Sleep recommendations
    if scores.avg_sleep_hours < 7:
        recommendations.append(
            f"Increase sleep duration: You're averaging {scores.avg_sleep_hours}h. "
            "Aim for 7-9 hours to reduce cortisol and support recovery."
        )
    if scores.avg_sleep_quality < 7:
        recommendations.append(
            "Improve sleep quality: Reduce screen time before bed, keep your room cool and dark, "
            "and maintain a consistent sleep schedule."
        )
    
    # Workout recommendations
    if scores.workout_days < 3:
        recommendations.append(
            f"Increase exercise frequency: You worked out {scores.workout_days} times. "
            "Aim for at least 3-5 sessions per week to boost dopamine and reduce stress."
        )
    elif scores.avg_workout_duration < 30:
        recommendations.append(
            f"Extend workout duration: Average of {scores.avg_workout_duration} min is short. "
            "Try to reach 30-45 minutes for optimal benefits."
        )
    
    # Nutrition recommendations
    if scores.avg_meals_per_day < 3:
        recommendations.append(
            f"Eat more regularly: Averaging {scores.avg_meals_per_day} meals/day. "
            "Regular meals stabilize blood sugar and cortisol levels."
        )
    if scores.avg_water_intake < 6:
        recommendations.append(
            f"Increase hydration: Only {scores.avg_water_intake} glasses/day. "
            "Aim for 8 glasses to support metabolism and cognitive function."
        )
    
    # Cortisol-specific
    if scores.cortisol_level > 60:
        recommendations.append(
            "High stress detected: Consider adding meditation, deep breathing, "
            "or light walking to your routine. Prioritize recovery."
        )
    
    # Positive reinforcement
    if scores.dopamine_level >= 70:
        recommendations.append(
            "Great progress! Your wellness habits are strong. "
            "Maintain consistency to keep dopamine levels high."
        )
    
    return recommendations if recommendations else ["Keep up the great work! Your wellness metrics are balanced."]


