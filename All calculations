def correlate_sleep_and_bp(
    sleep_logs: List[SleepLog],
    bp_logs: List[BloodPressureLog]
) -> dict:
    """
    Analyze correlation between sleep patterns and blood pressure.
    
    Returns correlation data and insights.
    """
    if not sleep_logs or not bp_logs:
        return {"correlation": 0, "insight": "Insufficient data for correlation analysis"}
    
    # Group by date
    sleep_by_date = {}
    for log in sleep_logs:
        date_key = log.sleep_end.date()
        analysis = analyze_sleep_log(log)
        sleep_by_date[date_key] = analysis.duration_hours
    
    bp_by_date = {}
    for log in bp_logs:
        date_key = log.recorded_at.date()
        if date_key not in bp_by_date:
            bp_by_date[date_key] = []
        bp_by_date[date_key].append(log.systolic)
    
    # Find matching dates
    matched_data = []
    for date_key in sleep_by_date:
        if date_key in bp_by_date:
            sleep_hours = sleep_by_date[date_key]
            avg_bp = mean(bp_by_date[date_key])
            matched_data.append((sleep_hours, avg_bp))
    
    if len(matched_data) < 3:
        return {"correlation": 0, "insight": "Need more matching data points"}
    
    # Simple correlation calculation
    sleep_vals = [d[0] for d in matched_data]
    bp_vals = [d[1] for d in matched_data]
    
    n = len(matched_data)
    sum_x = sum(sleep_vals)
    sum_y = sum(bp_vals)
    sum_xy = sum(x * y for x, y in matched_data)
    sum_x2 = sum(x ** 2 for x in sleep_vals)
    sum_y2 = sum(y ** 2 for y in bp_vals)
    
    numerator = (n * sum_xy) - (sum_x * sum_y)
    denominator = ((n * sum_x2 - sum_x ** 2) * (n * sum_y2 - sum_y ** 2)) ** 0.5
    
    correlation = numerator / denominator if denominator != 0 else 0
    
    # Generate insight
    if correlation < -0.3:
        insight = "Negative correlation: Better sleep tends to lower blood pressure"
    elif correlation > 0.3:
        insight = "Unexpected positive correlation: Consider other factors affecting BP"
    else:
        insight = "Weak correlation: Sleep and BP show limited direct relationship"
    
    return {
        "correlation": round(correlation, 3),
        "insight": insight,
        "data_points": len(matched_data),
        "avg_sleep": round(mean(sleep_vals), 1),
        "avg_bp": round(mean(bp_vals), 1)
    }
