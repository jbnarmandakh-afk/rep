def calculate_nutrition_score(logs: List[NutritionLog]) -> int:
    """
    Calculate nutrition health score (0-100).
    
    Based on:
    - Meal consistency (50%): Target 3 meals per day
    - Hydration (50%): Target 8 glasses of water
    """
    if not logs:
        return 50
    
    avg_meals = mean(log.meals for log in logs)
    avg_water = mean(log.water_glasses for log in logs)
    
    # Meal score (target: 3 meals)
    if avg_meals < 2:
        meal_score = 40
    elif avg_meals < 3:
        meal_score = 70
    elif 3 <= avg_meals <= 4:
        meal_score = 100
    else:
        meal_score = 80  # Too many meals/snacking
    
    # Water score (target: 8 glasses)
    water_score = min(100, (avg_water / 8) * 100)
    
    total_score = (meal_score * 0.5) + (water_score * 0.5)
    return round(min(100, max(0, total_score)))


