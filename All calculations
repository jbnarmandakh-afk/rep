def calculate_sleep_duration(sleep_start: datetime, sleep_end: datetime) -> float:
    """Calculate sleep duration in hours."""
    duration = sleep_end - sleep_start
    hours = duration.total_seconds() / 3600
    return round(hours, 2)


def get_sleep_quality_rating(quality: Optional[int]) -> SleepQualityRating:
    """Convert numeric quality (1-10) to rating category."""
    if quality is None:
        return SleepQualityRating.FAIR
    
    if quality >= 8:
        return SleepQualityRating.EXCELLENT
    elif quality >= 6:
        return SleepQualityRating.GOOD
    elif quality >= 4:
        return SleepQualityRating.FAIR
    else:
        return SleepQualityRating.POOR


def is_optimal_sleep_duration(hours: float) -> bool:
    """
    Check if sleep duration is within optimal range.
    
    Optimal range for adults: 7-9 hours (CDC recommendation)
    """
    return 7.0 <= hours <= 9.0


def analyze_sleep_log(log: SleepLog) -> SleepAnalysis:
    """Convert a sleep log to an analyzed entry with calculated fields."""
    duration = calculate_sleep_duration(log.sleep_start, log.sleep_end)
    
    return SleepAnalysis(
        sleep_id=log.sleep_id,
        sleep_start=log.sleep_start,
        sleep_end=log.sleep_end,
        duration_hours=duration,
        sleep_quality=log.sleep_quality,
        quality_rating=get_sleep_quality_rating(log.sleep_quality),
        is_optimal_duration=is_optimal_sleep_duration(duration),
        notes=log.notes
    )


def calculate_sleep_summary(logs: List[SleepLog]) -> SleepSummary:
    """Calculate summary statistics for sleep logs."""
    if not logs:
        return SleepSummary(
            avg_duration_hours=0,
            avg_quality=0,
            total_logs=0,
            optimal_nights_percent=0
        )
    
    analyses = [analyze_sleep_log(log) for log in logs]
    
    avg_duration = mean(a.duration_hours for a in analyses)
    
    # Quality average (only if available)
    quality_logs = [a.sleep_quality for a in analyses if a.sleep_quality is not None]
    avg_quality = mean(quality_logs) if quality_logs else 0
    
    # Optimal nights percentage
    optimal_count = sum(1 for a in analyses if a.is_optimal_duration)
    optimal_percent = (optimal_count / len(analyses)) * 100
    
    return SleepSummary(
        avg_duration_hours=round(avg_duration, 1),
        avg_quality=round(avg_quality, 1),
        total_logs=len(logs),
        optimal_nights_percent=round(optimal_percent, 1)
    )


def calculate_sleep_score(logs: List[SleepLog]) -> int:
    """
    Calculate sleep health score (0-100).
    
    Based on:
    - Duration (50%): 7-9 hours optimal
    - Quality (50%): 1-10 scale normalized
    """
    if not logs:
        return 50
    
    analyses = [analyze_sleep_log(log) for log in logs]
    
    # Duration score (optimal = 8 hours)
    avg_duration = mean(a.duration_hours for a in analyses)
    if avg_duration < 5:
        duration_score = 20
    elif avg_duration < 6:
        duration_score = 40
    elif avg_duration < 7:
        duration_score = 60
    elif 7 <= avg_duration <= 9:
        duration_score = 100
    elif avg_duration <= 10:
        duration_score = 80
    else:
        duration_score = 60  # Too much sleep
    
    # Quality score
    quality_logs = [a.sleep_quality for a in analyses if a.sleep_quality is not None]
    if quality_logs:
        avg_quality = mean(quality_logs)
        quality_score = (avg_quality / 10) * 100
    else:
        quality_score = 50
    
    # Combined score
    total_score = (duration_score * 0.5) + (quality_score * 0.5)
    return round(min(100, max(0, total_score)))


def analyze_sleep_bp_correlation(
    sleep_logs: List[SleepLog],
    bp_logs: Optional[List[BloodPressureLog]] = None
) -> SleepBPCorrelation:
    """
    Analyze how sleep patterns affect blood pressure risk.
    
    Research shows:
    - < 6 hours sleep: 20-30% increased hypertension risk
    - < 7 hours sleep: 5-10 mmHg higher systolic BP
    - Poor quality sleep disrupts autonomic nervous system
    - > 9 hours may indicate underlying health issues
    """
    if not sleep_logs:
        return SleepBPCorrelation(
            avg_hours=0,
            avg_quality=0,
            bp_risk_level=RiskLevel.MODERATE,
            warnings=[],
            estimated_bp_impact="Insufficient data"
        )
    
    analyses = [analyze_sleep_log(log) for log in sleep_logs]
    avg_hours = mean(a.duration_hours for a in analyses)
    
    quality_logs = [a.sleep_quality for a in analyses if a.sleep_quality is not None]
    avg_quality = mean(quality_logs) if quality_logs else 5.0
    
    warnings: List[HealthAlert] = []
    
    # Duration warnings
    if avg_hours < 6:
        warnings.append(HealthAlert(
            alert_type=AlertType.DANGER,
            title="Severe Sleep Deprivation",
            message=f"Averaging {avg_hours:.1f} hours of sleep",
            detail="Less than 6 hours of sleep significantly increases blood pressure and cortisol levels. "
                   "Research shows 20-30% elevated risk of hypertension. This also impairs glucose metabolism "
                   "and immune function."
        ))
    elif avg_hours < 7:
        warnings.append(HealthAlert(
            alert_type=AlertType.WARNING,
            title="Insufficient Sleep Duration",
            message=f"Averaging {avg_hours:.1f} hours of sleep",
            detail="Studies show 7-9 hours is optimal for adults. Chronic short sleep is linked to "
                   "elevated systolic BP (+5-10 mmHg) and increased cortisol production."
        ))
    
    if avg_hours > 9:
        warnings.append(HealthAlert(
            alert_type=AlertType.INFO,
            title="Excessive Sleep Duration",
            message=f"Averaging {avg_hours:.1f} hours of sleep",
            detail="Sleeping more than 9 hours regularly may indicate underlying health issues "
                   "such as depression, sleep apnea, or chronic fatigue. This is also associated "
                   "with increased cardiovascular risk."
        ))
    
    # Quality warnings
    if avg_quality < 5:
        warnings.append(HealthAlert(
            alert_type=AlertType.DANGER,
            title="Poor Sleep Quality",
            message=f"Quality score: {avg_quality:.1f}/10",
            detail="Poor sleep quality disrupts your autonomic nervous system, increasing cortisol "
                   "and adrenaline which raises blood pressure. Fragmented sleep prevents adequate "
                   "nocturnal BP dipping, a key recovery mechanism."
        ))
    elif avg_quality < 7:
        warnings.append(HealthAlert(
            alert_type=AlertType.WARNING,
            title="Below Optimal Sleep Quality",
            message=f"Quality score: {avg_quality:.1f}/10",
            detail="Aim for 7+ quality score. Fragmented or light sleep prevents adequate BP dipping "
                   "during rest and impairs cortisol regulation."
        ))
    
    # Determine risk level
    if avg_hours < 6 or avg_quality < 5:
        risk_level = RiskLevel.HIGH
        bp_impact = "High risk: Estimated +10-15 mmHg systolic impact"
    elif avg_hours < 7 or avg_quality < 7:
        risk_level = RiskLevel.MODERATE
        bp_impact = "Moderate risk: Estimated +5-10 mmHg systolic impact"
    else:
        risk_level = RiskLevel.LOW
        bp_impact = "Low risk: Sleep patterns support healthy BP"
    
    return SleepBPCorrelation(
        avg_hours=round(avg_hours, 1),
        avg_quality=round(avg_quality, 1),
        bp_risk_level=risk_level,
        warnings=warnings,
        estimated_bp_impact=bp_impact
    )


