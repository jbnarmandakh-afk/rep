def calculate_bmi(weight_kg: float, height_cm: float) -> float:
    """
    Calculate Body Mass Index.
    
    BMI = weight_kg / (height_m)^2
    
    Categories:
    - Underweight: < 18.5
    - Normal: 18.5 - 24.9
    - Overweight: 25 - 29.9
    - Obese: >= 30
    """
    height_m = height_cm / 100
    bmi = weight_kg / (height_m ** 2)
    return round(bmi, 1)


def get_bmi_category(bmi: float) -> str:
    """Get BMI category label."""
    if bmi < 18.5:
        return "Underweight"
    elif bmi < 25:
        return "Normal"
    elif bmi < 30:
        return "Overweight"
    else:
        return "Obese"


def calculate_ideal_weight_range(height_cm: float) -> Tuple[float, float]:
    """
    Calculate ideal weight range based on height.
    Uses BMI range of 18.5 - 24.9 as healthy.
    """
    height_m = height_cm / 100
    min_weight = 18.5 * (height_m ** 2)
    max_weight = 24.9 * (height_m ** 2)
    return (round(min_weight, 1), round(max_weight, 1))


def analyze_metric_trend(metrics: List[HealthMetric]) -> str:
    """Analyze trend for a specific metric type."""
    if len(metrics) < 2:
        return "stable"
    
    sorted_metrics = sorted(metrics, key=lambda x: x.recorded_at, reverse=True)
    mid = len(sorted_metrics) // 2
    
    recent_avg = mean(m.value for m in sorted_metrics[:mid])
    older_avg = mean(m.value for m in sorted_metrics[mid:])
    
    diff_percent = ((recent_avg - older_avg) / older_avg) * 100 if older_avg != 0 else 0
    
    if diff_percent < -5:
        return "decreasing"
    elif diff_percent > 5:
        return "increasing"
    else:
        return "stable"


