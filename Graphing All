def plot_dopamine_vs_cortisol(
    daily_data: List[DailyWellnessEntry],
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """
    Plot Dopamine (green) vs Cortisol (red) over time.
    This is the main mental health visualization.
    """
    if not daily_data:
        raise ValueError("No daily wellness data provided")
    
    sorted_data = sorted(daily_data, key=lambda x: x.date)
    
    dates = [d.date for d in sorted_data]
    dopamine = [d.dopamine for d in sorted_data]
    cortisol = [d.cortisol for d in sorted_data]
    
    fig, ax = plt.subplots(figsize=(14, 7))
    
    # Fill areas
    ax.fill_between(dates, dopamine, alpha=0.4, color=COLORS['dopamine'], label='Dopamine (Wellness)')
    ax.fill_between(dates, cortisol, alpha=0.4, color=COLORS['cortisol'], label='Cortisol (Stress)')
    
    # Lines
    ax.plot(dates, dopamine, color=COLORS['dopamine'], linewidth=3, marker='o', 
            markersize=8, label=f'Dopamine avg: {sum(dopamine)/len(dopamine):.0f}')
    ax.plot(dates, cortisol, color=COLORS['cortisol'], linewidth=3, marker='s', 
            markersize=7, label=f'Cortisol avg: {sum(cortisol)/len(cortisol):.0f}')
    
    # Reference lines
    ax.axhline(y=70, color=COLORS['dopamine'], linestyle='--', alpha=0.5, linewidth=1)
    ax.axhline(y=40, color=COLORS['cortisol'], linestyle='--', alpha=0.5, linewidth=1)
    
    ax.annotate('Target Dopamine ≥70', xy=(dates[-1], 70), xytext=(5, 5), 
                textcoords='offset points', fontsize=8, color=COLORS['dopamine'])
    ax.annotate('Target Cortisol ≤40', xy=(dates[-1], 40), xytext=(5, -10), 
                textcoords='offset points', fontsize=8, color=COLORS['cortisol'])
    
    ax.set_xlabel('Date')
    ax.set_ylabel('Level (0-100)')
    ax.set_title('Mental Health: Dopamine vs Cortisol', fontsize=14, fontweight='bold')
    ax.set_ylim(0, 105)
    ax.legend(loc='upper right')
    ax.grid(True, alpha=0.3)
    
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.xticks(rotation=45)
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


def plot_wellness_breakdown(
    scores: WellnessScores,
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """Plot wellness score breakdown as a radar/spider chart."""
    categories = ['Sleep', 'Workout', 'Nutrition', 'Dopamine', 'Stress\nManagement']
    values = [
        scores.sleep_score,
        scores.workout_score,
        scores.nutrition_score,
        scores.dopamine_level,
        100 - scores.cortisol_level  # Invert cortisol for "stress management"
    ]
    
    # Number of variables
    N = len(categories)
    
    # Compute angle for each category
    angles = [n / float(N) * 2 * 3.14159 for n in range(N)]
    values_plot = values + [values[0]]  # Close the radar
    angles += angles[:1]
    
    fig, ax = plt.subplots(figsize=(8, 8), subplot_kw=dict(polar=True))
    
    # Draw the radar chart
    ax.plot(angles, values_plot, color=COLORS['primary'], linewidth=2)
    ax.fill(angles, values_plot, color=COLORS['primary'], alpha=0.25)
    
    # Add markers at each point
    for angle, val, cat in zip(angles[:-1], values, categories):
        ax.plot(angle, val, 'o', color=COLORS['accent'], markersize=10)
        # Add value label
        ax.annotate(f'{val}', xy=(angle, val), xytext=(5, 5), 
                   textcoords='offset points', fontsize=10, fontweight='bold')
    
    # Set category labels
    ax.set_xticks(angles[:-1])
    ax.set_xticklabels(categories, fontsize=11)
    
    # Set radial limits
    ax.set_ylim(0, 100)
    ax.set_yticks([20, 40, 60, 80, 100])
    ax.set_yticklabels(['20', '40', '60', '80', '100'], fontsize=8)
    
    ax.set_title('Wellness Score Breakdown', fontsize=14, fontweight='bold', pad=20)
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


def plot_wellness_gauges(
    scores: WellnessScores,
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """Plot dopamine and cortisol as gauge meters."""
    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    
    for idx, (ax, (label, value, color, good_high)) in enumerate(zip(
        axes,
        [
            ('Dopamine Level', scores.dopamine_level, COLORS['dopamine'], True),
            ('Cortisol Level', scores.cortisol_level, COLORS['cortisol'], False)
        ]
    )):
        # Create semi-circle gauge
        import numpy as np
        
        # Background arc (full semi-circle)
        theta_bg = np.linspace(0, np.pi, 100)
        r_bg = 1
        x_bg = r_bg * np.cos(theta_bg)
        y_bg = r_bg * np.sin(theta_bg)
        ax.fill_between(x_bg, 0, y_bg, color=COLORS['card'], alpha=0.5)
        
        # Value arc
        value_angle = (value / 100) * np.pi
        theta_val = np.linspace(0, value_angle, 50)
        x_val = 0.95 * np.cos(theta_val)
        y_val = 0.95 * np.sin(theta_val)
        ax.fill_between(x_val, 0, y_val, color=color, alpha=0.7)
        
        # Outer border
        ax.plot(x_bg, y_bg, color=COLORS['muted'], linewidth=2)
        ax.plot([-1, 1], [0, 0], color=COLORS['muted'], linewidth=2)
        
        # Needle
        needle_angle = value_angle
        needle_x = 0.7 * np.cos(needle_angle)
        needle_y = 0.7 * np.sin(needle_angle)
        ax.annotate('', xy=(needle_x, needle_y), xytext=(0, 0),
                    arrowprops=dict(arrowstyle='->', color=COLORS['text'], lw=3))
        
        # Center dot
        ax.plot(0, 0, 'o', color=COLORS['text'], markersize=15)
        
        # Value text
        ax.text(0, 0.3, f'{value}', ha='center', va='center', 
                fontsize=36, fontweight='bold', color=color)
        
        # Label
        ax.text(0, -0.3, label, ha='center', va='center', 
                fontsize=14, fontweight='bold', color=COLORS['text'])
        
        # Status text
        if good_high:
            status = 'Excellent' if value >= 70 else 'Good' if value >= 50 else 'Low'
        else:
            status = 'Low' if value <= 40 else 'Moderate' if value <= 60 else 'High'
        
        status_color = COLORS['success'] if (good_high and value >= 70) or (not good_high and value <= 40) else \
                       COLORS['warning'] if (good_high and value >= 50) or (not good_high and value <= 60) else \
                       COLORS['danger']
        
        ax.text(0, -0.5, status, ha='center', va='center', 
                fontsize=12, color=status_color)
        
        ax.set_xlim(-1.2, 1.2)
        ax.set_ylim(-0.7, 1.2)
        ax.set_aspect('equal')
        ax.axis('off')
    
    fig.suptitle('Mental Health Meters', fontsize=16, fontweight='bold', y=1.02)
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


def plot_daily_factors(
    daily_data: List[DailyWellnessEntry],
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """Plot daily factors (sleep, workout, meals, water) that affect wellness."""
    if not daily_data:
        raise ValueError("No daily wellness data provided")
    
    sorted_data = sorted(daily_data, key=lambda x: x.date)
    
    dates = [d.date for d in sorted_data]
    sleep = [d.sleep_hours for d in sorted_data]
    workout = [d.workout_minutes for d in sorted_data]
    meals = [d.meals for d in sorted_data]
    water = [d.water_glasses for d in sorted_data]
    
    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    
    # Sleep
    ax = axes[0, 0]
    colors = [COLORS['success'] if 7 <= s <= 9 else COLORS['warning'] if s >= 6 else COLORS['danger'] for s in sleep]
    ax.bar(dates, sleep, color=colors, edgecolor='white', linewidth=0.5)
    ax.axhline(y=7, color=COLORS['accent'], linestyle='--', alpha=0.7, label='Min target (7h)')
    ax.axhline(y=9, color=COLORS['accent'], linestyle='--', alpha=0.7, label='Max target (9h)')
    ax.set_ylabel('Hours')
    ax.set_title('Sleep Duration')
    ax.legend(loc='upper right', fontsize=8)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.setp(ax.xaxis.get_majorticklabels(), rotation=45)
    
    # Workout
    ax = axes[0, 1]
    colors = [COLORS['success'] if w >= 30 else COLORS['warning'] if w > 0 else COLORS['danger'] for w in workout]
    ax.bar(dates, workout, color=colors, edgecolor='white', linewidth=0.5)
    ax.axhline(y=30, color=COLORS['accent'], linestyle='--', alpha=0.7, label='Target (30 min)')
    ax.set_ylabel('Minutes')
    ax.set_title('Workout Duration')
    ax.legend(loc='upper right', fontsize=8)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.setp(ax.xaxis.get_majorticklabels(), rotation=45)
    
    # Meals
    ax = axes[1, 0]
    colors = [COLORS['success'] if m >= 3 else COLORS['warning'] if m >= 2 else COLORS['danger'] for m in meals]
    ax.bar(dates, meals, color=colors, edgecolor='white', linewidth=0.5)
    ax.axhline(y=3, color=COLORS['accent'], linestyle='--', alpha=0.7, label='Target (3 meals)')
    ax.set_ylabel('Meals')
    ax.set_title('Daily Meals')
    ax.legend(loc='upper right', fontsize=8)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.setp(ax.xaxis.get_majorticklabels(), rotation=45)
    
    # Water
    ax = axes[1, 1]
    colors = [COLORS['success'] if w >= 8 else COLORS['warning'] if w >= 6 else COLORS['danger'] for w in water]
    ax.bar(dates, water, color=colors, edgecolor='white', linewidth=0.5)
    ax.axhline(y=8, color=COLORS['accent'], linestyle='--', alpha=0.7, label='Target (8 glasses)')
    ax.set_ylabel('Glasses')
    ax.set_title('Water Intake')
    ax.legend(loc='upper right', fontsize=8)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.setp(ax.xaxis.get_majorticklabels(), rotation=45)
    
    fig.suptitle('Daily Wellness Factors', fontsize=14, fontweight='bold')
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


