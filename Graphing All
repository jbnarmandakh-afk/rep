def plot_sleep_duration(
    logs: List[SleepLog],
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """Plot sleep duration over time with optimal range highlight."""
    if not logs:
        raise ValueError("No sleep logs provided")
    
    sorted_logs = sorted(logs, key=lambda x: x.sleep_end)
    analyses = [analyze_sleep_log(log) for log in sorted_logs]
    
    dates = [a.sleep_end.date() for a in analyses]
    durations = [a.duration_hours for a in analyses]
    
    fig, ax = plt.subplots(figsize=(12, 6))
    
    # Optimal range background
    ax.axhspan(7, 9, alpha=0.2, color=COLORS['success'], label='Optimal (7-9h)')
    ax.axhspan(6, 7, alpha=0.1, color=COLORS['warning'])
    ax.axhspan(0, 6, alpha=0.1, color=COLORS['danger'])
    
    # Bar chart with color coding
    colors = []
    for d in durations:
        if 7 <= d <= 9:
            colors.append(COLORS['success'])
        elif 6 <= d < 7:
            colors.append(COLORS['warning'])
        else:
            colors.append(COLORS['danger'])
    
    bars = ax.bar(dates, durations, color=colors, edgecolor='white', linewidth=0.5, width=0.8)
    
    # Average line
    avg_duration = sum(durations) / len(durations)
    ax.axhline(y=avg_duration, color=COLORS['accent'], linestyle='-', 
               linewidth=2, label=f'Average: {avg_duration:.1f}h')
    
    ax.set_xlabel('Date')
    ax.set_ylabel('Hours')
    ax.set_title('Sleep Duration')
    ax.legend(loc='upper right')
    ax.set_ylim(0, max(durations) + 2)
    
    # Format x-axis
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.xticks(rotation=45)
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


