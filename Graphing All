def plot_blood_pressure_trend(
    logs: List[BloodPressureLog],
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """
    Plot blood pressure trend over time with systolic/diastolic lines.
    Includes AHA reference zones.
    """
    if not logs:
        raise ValueError("No blood pressure logs provided")
    
    sorted_logs = sorted(logs, key=lambda x: x.recorded_at)
    
    dates = [log.recorded_at for log in sorted_logs]
    systolic = [log.systolic for log in sorted_logs]
    diastolic = [log.diastolic for log in sorted_logs]
    
    fig, ax = plt.subplots(figsize=(12, 6))
    
    # Add reference zones
    ax.axhspan(0, 80, alpha=0.1, color=COLORS['success'], label='Normal Diastolic Zone')
    ax.axhspan(80, 90, alpha=0.1, color=COLORS['warning'])
    ax.axhspan(90, 120, alpha=0.1, color=COLORS['danger'])
    
    ax.axhline(y=120, color=COLORS['muted'], linestyle='--', alpha=0.5, linewidth=1)
    ax.axhline(y=80, color=COLORS['muted'], linestyle='--', alpha=0.5, linewidth=1)
    ax.axhline(y=140, color=COLORS['danger'], linestyle='--', alpha=0.5, linewidth=1)
    
    # Plot lines
    ax.plot(dates, systolic, color=COLORS['systolic'], linewidth=2, marker='o', 
            markersize=6, label=f'Systolic (avg: {sum(systolic)/len(systolic):.0f})')
    ax.plot(dates, diastolic, color=COLORS['diastolic'], linewidth=2, marker='s', 
            markersize=5, label=f'Diastolic (avg: {sum(diastolic)/len(diastolic):.0f})')
    
    # Fill between
    ax.fill_between(dates, systolic, diastolic, alpha=0.2, color=COLORS['primary'])
    
    # Annotations
    ax.annotate('Normal <120', xy=(dates[-1], 120), xytext=(5, 0), 
                textcoords='offset points', fontsize=8, color=COLORS['muted'])
    ax.annotate('Normal <80', xy=(dates[-1], 80), xytext=(5, 0), 
                textcoords='offset points', fontsize=8, color=COLORS['muted'])
    ax.annotate('High ≥140', xy=(dates[-1], 140), xytext=(5, 0), 
                textcoords='offset points', fontsize=8, color=COLORS['danger'])
    
    ax.set_xlabel('Date')
    ax.set_ylabel('mmHg')
    ax.set_title('Blood Pressure Trend')
    ax.legend(loc='upper left')
    ax.grid(True, alpha=0.3)
    
    # Format x-axis dates
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    ax.xaxis.set_major_locator(mdates.DayLocator(interval=max(1, len(dates)//7)))
    plt.xticks(rotation=45)
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


def plot_bp_distribution(
    logs: List[BloodPressureLog],
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """Plot distribution of BP readings by category."""
    if not logs:
        raise ValueError("No blood pressure logs provided")
    
    # Categorize readings
    categories = {}
    for log in logs:
        cat = categorize_blood_pressure(log.systolic, log.diastolic)
        categories[cat.value] = categories.get(cat.value, 0) + 1
    
    # Define order and colors
    order = [
        BPCategory.NORMAL.value,
        BPCategory.ELEVATED.value,
        BPCategory.HYPERTENSION_STAGE_1.value,
        BPCategory.HYPERTENSION_STAGE_2.value,
        BPCategory.HYPERTENSIVE_CRISIS.value,
        BPCategory.LOW.value,
    ]
    cat_colors = {
        BPCategory.NORMAL.value: COLORS['success'],
        BPCategory.ELEVATED.value: COLORS['warning'],
        BPCategory.HYPERTENSION_STAGE_1.value: '#F39C12',
        BPCategory.HYPERTENSION_STAGE_2.value: COLORS['danger'],
        BPCategory.HYPERTENSIVE_CRISIS.value: '#8E44AD',
        BPCategory.LOW.value: COLORS['primary'],
    }
    
    labels = [cat for cat in order if cat in categories]
    values = [categories[cat] for cat in labels]
    colors = [cat_colors[cat] for cat in labels]
    
    fig, ax = plt.subplots(figsize=(10, 6))
    
    bars = ax.bar(labels, values, color=colors, edgecolor='white', linewidth=1)
    
    # Add value labels on bars
    for bar, val in zip(bars, values):
        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.1,
                str(val), ha='center', va='bottom', fontsize=10, color=COLORS['text'])
    
    ax.set_xlabel('Category')
    ax.set_ylabel('Number of Readings')
    ax.set_title('Blood Pressure Readings by Category')
    plt.xticks(rotation=30, ha='right')
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


def plot_bp_with_heart_rate(
    logs: List[BloodPressureLog],
    save_path: Optional[str] = None,
    show: bool = True
) -> plt.Figure:
    """Plot BP with heart rate on secondary axis."""
    if not logs:
        raise ValueError("No blood pressure logs provided")
    
    sorted_logs = sorted(logs, key=lambda x: x.recorded_at)
    logs_with_hr = [log for log in sorted_logs if log.heart_rate is not None]
    
    if not logs_with_hr:
        return plot_blood_pressure_trend(logs, save_path, show)
    
    dates = [log.recorded_at for log in logs_with_hr]
    systolic = [log.systolic for log in logs_with_hr]
    diastolic = [log.diastolic for log in logs_with_hr]
    heart_rates = [log.heart_rate for log in logs_with_hr]
    
    fig, ax1 = plt.subplots(figsize=(12, 6))
    
    # Blood pressure on primary axis
    ax1.plot(dates, systolic, color=COLORS['systolic'], linewidth=2, marker='o', 
             markersize=6, label='Systolic')
    ax1.plot(dates, diastolic, color=COLORS['diastolic'], linewidth=2, marker='s', 
             markersize=5, label='Diastolic')
    ax1.fill_between(dates, systolic, diastolic, alpha=0.2, color=COLORS['primary'])
    
    ax1.set_xlabel('Date')
    ax1.set_ylabel('Blood Pressure (mmHg)', color=COLORS['text'])
    ax1.tick_params(axis='y', labelcolor=COLORS['text'])
    
    # Heart rate on secondary axis
    ax2 = ax1.twinx()
    ax2.plot(dates, heart_rates, color=COLORS['heart_rate'], linewidth=2, 
             marker='^', markersize=5, linestyle='--', label='Heart Rate')
    ax2.set_ylabel('Heart Rate (BPM)', color=COLORS['heart_rate'])
    ax2.tick_params(axis='y', labelcolor=COLORS['heart_rate'])
    
    # Combined legend
    lines1, labels1 = ax1.get_legend_handles_labels()
    lines2, labels2 = ax2.get_legend_handles_labels()
    ax1.legend(lines1 + lines2, labels1 + labels2, loc='upper left')
    
    ax1.set_title('Blood Pressure & Heart Rate Trend')
    ax1.grid(True, alpha=0.3)
    
    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))
    plt.xticks(rotation=45)
    
    plt.tight_layout()
    
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
    if show:
        plt.show()
    
    return fig


