class TestBloodPressureCategorization:
    """Tests for blood pressure categorization."""

    def test_normal_blood_pressure(self):
        """Test normal BP reading (systolic < 120 and diastolic < 80)."""
        assert categorize_blood_pressure(110, 70) == BPCategory.NORMAL
        assert categorize_blood_pressure(115, 75) == BPCategory.NORMAL
        assert categorize_blood_pressure(119, 79) == BPCategory.NORMAL

    def test_elevated_blood_pressure(self):
        """Test elevated BP (systolic 120-129 and diastolic < 80)."""
        assert categorize_blood_pressure(120, 75) == BPCategory.ELEVATED
        assert categorize_blood_pressure(125, 78) == BPCategory.ELEVATED
        assert categorize_blood_pressure(129, 79) == BPCategory.ELEVATED

    def test_high_stage_1(self):
        """Test high stage 1 (systolic 130-139 or diastolic 80-89)."""
        assert categorize_blood_pressure(130, 75) == BPCategory.HIGH_STAGE_1
        assert categorize_blood_pressure(125, 80) == BPCategory.HIGH_STAGE_1
        assert categorize_blood_pressure(135, 85) == BPCategory.HIGH_STAGE_1

    def test_high_stage_2(self):
        """Test high stage 2 (systolic >= 140 or diastolic >= 90)."""
        assert categorize_blood_pressure(140, 85) == BPCategory.HIGH_STAGE_2
        assert categorize_blood_pressure(135, 90) == BPCategory.HIGH_STAGE_2
        assert categorize_blood_pressure(150, 95) == BPCategory.HIGH_STAGE_2

    def test_hypertensive_crisis(self):
        """Test hypertensive crisis (systolic >= 180 or diastolic >= 120)."""
        assert categorize_blood_pressure(180, 100) == BPCategory.HYPERTENSIVE_CRISIS
        assert categorize_blood_pressure(160, 120) == BPCategory.HYPERTENSIVE_CRISIS
        assert categorize_blood_pressure(190, 130) == BPCategory.HYPERTENSIVE_CRISIS


class TestBloodPressureCalculations:
    """Tests for BP calculation functions."""

    def test_mean_arterial_pressure(self):
        """Test MAP calculation."""
        # MAP = Diastolic + (1/3 * (Systolic - Diastolic))
        assert calculate_mean_arterial_pressure(120, 80) == pytest.approx(93.33, rel=0.01)
        assert calculate_mean_arterial_pressure(140, 90) == pytest.approx(106.67, rel=0.01)

    def test_pulse_pressure(self):
        """Test pulse pressure calculation."""
        assert calculate_pulse_pressure(120, 80) == 40
        assert calculate_pulse_pressure(140, 90) == 50
        assert calculate_pulse_pressure(100, 70) == 30


