class TestWellnessCalculations:
    """Tests for wellness and mental health calculations."""

    @pytest.fixture
    def healthy_data(self):
        """Data for a healthy lifestyle."""
        sleep_logs = [
            SleepLog(id=1, sleep_start="2026-03-31T23:00:00", sleep_end="2026-04-01T07:00:00", sleep_quality=8),
            SleepLog(id=2, sleep_start="2026-03-30T23:00:00", sleep_end="2026-03-31T07:30:00", sleep_quality=9),
        ]
        workouts = [
            Workout(id=1, workout_type="Strength", duration_min=45, calories_burned=320, recorded_at="2026-04-01"),
            Workout(id=2, workout_type="Cardio", duration_min=40, calories_burned=300, recorded_at="2026-03-30"),
            Workout(id=3, workout_type="HIIT", duration_min=30, calories_burned=350, recorded_at="2026-03-29"),
            Workout(id=4, workout_type="Yoga", duration_min=45, calories_burned=150, recorded_at="2026-03-28"),
            Workout(id=5, workout_type="Strength", duration_min=50, calories_burned=340, recorded_at="2026-03-27"),
        ]
        nutrition = [
            NutritionLog(id=1, date="2026-04-01", meals=3, calories=2100, protein=120, water=8),
            NutritionLog(id=2, date="2026-03-31", meals=3, calories=2050, protein=115, water=8),
        ]
        return sleep_logs, workouts, nutrition

    @pytest.fixture
    def unhealthy_data(self):
        """Data for an unhealthy lifestyle."""
        sleep_logs = [
            SleepLog(id=1, sleep_start="2026-04-01T01:00:00", sleep_end="2026-04-01T05:00:00", sleep_quality=3),
            SleepLog(id=2, sleep_start="2026-03-31T02:00:00", sleep_end="2026-03-31T06:00:00", sleep_quality=4),
        ]
        workouts = []  # No workouts
        nutrition = [
            NutritionLog(id=1, date="2026-04-01", meals=1, calories=1000, protein=30, water=2),
        ]
        return sleep_logs, workouts, nutrition

    def test_healthy_lifestyle_high_dopamine(self, healthy_data):
        """Test that healthy habits result in high dopamine, low cortisol."""
        sleep_logs, workouts, nutrition = healthy_data
        result = calculate_wellness_scores(sleep_logs, workouts, nutrition)
        
        assert result["dopamine_level"] >= 70
        assert result["cortisol_level"] <= 40
        assert result["overall_wellness"] >= 60

    def test_unhealthy_lifestyle_high_cortisol(self, unhealthy_data):
        """Test that poor habits result in low dopamine, high cortisol."""
        sleep_logs, workouts, nutrition = unhealthy_data
        result = calculate_wellness_scores(sleep_logs, workouts, nutrition)
        
        assert result["dopamine_level"] <= 50
        assert result["cortisol_level"] >= 50

    def test_wellness_status(self):
        """Test wellness status descriptions."""
        assert "thriving" in get_wellness_status(80, 20).lower()
        assert "stress" in get_wellness_status(30, 70).lower()

    def test_wellness_recommendations(self, unhealthy_data):
        """Test that recommendations are generated for poor wellness."""
        sleep_logs, workouts, nutrition = unhealthy_data
        scores = calculate_wellness_scores(sleep_logs, workouts, nutrition)
        recommendations = generate_wellness_recommendations(scores)
        
        assert len(recommendations) > 0
        # Should have sleep, workout, and possibly nutrition recommendations
        assert any("sleep" in r.lower() for r in recommendations)


