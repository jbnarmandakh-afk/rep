class TestEdgeCases:
    """Tests for edge cases and boundary conditions."""

    def test_empty_data_handling(self):
        """Test all functions handle empty data gracefully."""
        assert analyze_blood_pressure_trends([])["readings_count"] == 0
        assert analyze_sleep_logs([])["total_nights"] == 0
        assert analyze_workout_stats([])["total_workouts"] == 0
        assert analyze_nutrition_logs([])["avg_meals"] == 0
        
        result = calculate_wellness_scores([], [], [])
        assert result["dopamine_level"] == 0
        assert result["cortisol_level"] == 100

    def test_boundary_values_bp(self):
        """Test BP categorization at exact boundaries."""
        # Exactly 120/80 is elevated (systolic 120, diastolic < 80)
        assert categorize_blood_pressure(120, 79) == BPCategory.ELEVATED
        
        # Exactly 130/80 is high stage 1
        assert categorize_blood_pressure(130, 80) == BPCategory.HIGH_STAGE_1

    def test_boundary_values_sleep(self):
        """Test sleep score at boundary values."""
        # Exactly 7 hours - should be optimal
        score_7h = calculate_sleep_score(7.0, 8)
        assert score_7h >= 80

        # Just under 7 hours
        score_6_9h = calculate_sleep_score(6.9, 8)
        assert score_6_9h < score_7h


