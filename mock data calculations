class TestSleepCalculations:
    """Tests for sleep calculation functions."""

    def test_sleep_duration_calculation(self):
        """Test sleep duration in hours."""
        # 8 hours of sleep
        duration = calculate_sleep_duration_hours(
            "2026-03-31T23:00:00",
            "2026-04-01T07:00:00"
        )
        assert duration == 8.0

        # 7.5 hours of sleep
        duration = calculate_sleep_duration_hours(
            "2026-03-31T23:30:00",
            "2026-04-01T07:00:00"
        )
        assert duration == 7.5

    def test_sleep_quality_labels(self):
        """Test sleep quality label conversion."""
        assert get_sleep_quality_label(9) == "Excellent"
        assert get_sleep_quality_label(8) == "Excellent"
        assert get_sleep_quality_label(7) == "Good"
        assert get_sleep_quality_label(6) == "Good"
        assert get_sleep_quality_label(5) == "Fair"
        assert get_sleep_quality_label(4) == "Fair"
        assert get_sleep_quality_label(3) == "Poor"
        assert get_sleep_quality_label(1) == "Poor"

    def test_sleep_score_optimal(self):
        """Test sleep score for optimal sleep (7-9 hours, high quality)."""
        # Perfect sleep: 8 hours, quality 10
        score = calculate_sleep_score(8.0, 10)
        assert score == 100.0

        # Good sleep: 7.5 hours, quality 8
        score = calculate_sleep_score(7.5, 8)
        assert score >= 80

    def test_sleep_score_poor(self):
        """Test sleep score for poor sleep."""
        # Short sleep: 5 hours, quality 4
        score = calculate_sleep_score(5.0, 4)
        assert score < 60

        # Very short: 4 hours, quality 3
        score = calculate_sleep_score(4.0, 3)
        assert score < 50


