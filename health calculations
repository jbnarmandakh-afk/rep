class BPCategory(Enum):
    """Blood pressure categories per AHA guidelines."""
    NORMAL = "Normal"
    ELEVATED = "Elevated"
    HIGH_STAGE_1 = "High Stage 1"
    HIGH_STAGE_2 = "High Stage 2"
    HYPERTENSIVE_CRISIS = "Hypertensive Crisis"


class RiskLevel(Enum):
    """Risk level classification."""
    LOW = "low"
    MODERATE = "moderate"
    HIGH = "high"


# =============================================================================
# Blood Pressure Calculations
# =============================================================================

def categorize_blood_pressure(systolic: int, diastolic: int) -> BPCategory:
    """
    Categorize blood pressure reading per AHA guidelines.
    
    Args:
        systolic: Systolic pressure (mmHg)
        diastolic: Diastolic pressure (mmHg)
    
    Returns:
        BPCategory enum value
    
    Reference:
        American Heart Association Blood Pressure Categories
    """
    if systolic >= 180 or diastolic >= 120:
        return BPCategory.HYPERTENSIVE_CRISIS
    elif systolic >= 140 or diastolic >= 90:
        return BPCategory.HIGH_STAGE_2
    elif systolic >= 130 or diastolic >= 80:
        return BPCategory.HIGH_STAGE_1
    elif systolic >= 120 and diastolic < 80:
        return BPCategory.ELEVATED
    else:
        return BPCategory.NORMAL


def calculate_mean_arterial_pressure(systolic: int, diastolic: int) -> float:
    """
    Calculate Mean Arterial Pressure (MAP).
    
    MAP = Diastolic + (1/3 * Pulse Pressure)
    where Pulse Pressure = Systolic - Diastolic
    
    Args:
        systolic: Systolic pressure (mmHg)
        diastolic: Diastolic pressure (mmHg)
    
    Returns:
        Mean arterial pressure (mmHg)
    """
    pulse_pressure = systolic - diastolic
    return diastolic + (pulse_pressure / 3)


def calculate_pulse_pressure(systolic: int, diastolic: int) -> int:
    """
    Calculate pulse pressure.
    
    Args:
        systolic: Systolic pressure (mmHg)
        diastolic: Diastolic pressure (mmHg)
    
    Returns:
        Pulse pressure (mmHg)
    """
    return systolic - diastolic


def analyze_blood_pressure_trends(logs: list[BloodPressureLog]) -> dict:
    """
    Analyze blood pressure trends from multiple readings.
    
    Args:
        logs: List of blood pressure logs
    
    Returns:
        Dictionary with trend analysis including averages, min, max, and trend direction
    """
    if not logs:
        return {
            "avg_systolic": 0,
            "avg_diastolic": 0,
            "avg_heart_rate": 0,
            "min_systolic": 0,
            "max_systolic": 0,
            "min_diastolic": 0,
            "max_diastolic": 0,
            "trend": "insufficient_data",
            "category": BPCategory.NORMAL,
            "readings_count": 0
        }
    
    systolic_values = [log.systolic for log in logs]
    diastolic_values = [log.diastolic for log in logs]
    heart_rate_values = [log.heart_rate for log in logs]
    
    avg_systolic = sum(systolic_values) / len(systolic_values)
    avg_diastolic = sum(diastolic_values) / len(diastolic_values)
    avg_heart_rate = sum(heart_rate_values) / len(heart_rate_values)
    
    # Determine trend (comparing first half to second half)
    if len(logs) >= 4:
        mid = len(logs) // 2
        first_half_avg = sum(systolic_values[:mid]) / mid
        second_half_avg = sum(systolic_values[mid:]) / (len(logs) - mid)
        
        if second_half_avg > first_half_avg + 3:
            trend = "increasing"
        elif second_half_avg < first_half_avg - 3:
            trend = "decreasing"
        else:
            trend = "stable"
    else:
        trend = "insufficient_data"
    
    return {
        "avg_systolic": round(avg_systolic, 1),
        "avg_diastolic": round(avg_diastolic, 1),
        "avg_heart_rate": round(avg_heart_rate, 1),
        "min_systolic": min(systolic_values),
        "max_systolic": max(systolic_values),
        "min_diastolic": min(diastolic_values),
        "max_diastolic": max(diastolic_values),
        "trend": trend,
        "category": categorize_blood_pressure(round(avg_systolic), round(avg_diastolic)),
        "readings_count": len(logs)
    }


# =============================================================================
# Sleep Calculations
# =============================================================================

def calculate_sleep_duration_hours(sleep_start: str, sleep_end: str) -> float:
    """
    Calculate sleep duration in hours.
    
    Args:
        sleep_start: ISO format datetime string
        sleep_end: ISO format datetime string
    
    Returns:
        Sleep duration in hours
    """
    start = datetime.fromisoformat(sleep_start)
    end = datetime.fromisoformat(sleep_end)
    duration = (end - start).total_seconds() / 3600
    return round(duration, 2)


def get_sleep_quality_label(quality: int) -> str:
    """
    Convert numeric sleep quality to descriptive label.
    
    Args:
        quality: Sleep quality score (1-10)
    
    Returns:
        Descriptive label
    """
    if quality >= 8:
        return "Excellent"
    elif quality >= 6:
        return "Good"
    elif quality >= 4:
        return "Fair"
    else:
        return "Poor"


def calculate_sleep_score(duration_hours: float, quality: int) -> float:
    """
    Calculate overall sleep score (0-100).
    
    Factors:
    - Duration: 50% weight (optimal is 7-9 hours)
    - Quality: 50% weight (scale 1-10)
    
    Args:
        duration_hours: Sleep duration in hours
        quality: Sleep quality (1-10)
    
    Returns:
        Sleep score (0-100)
    """
    # Duration score (optimal is 8 hours)
    if duration_hours >= 7 and duration_hours <= 9:
        duration_score = 100
    elif duration_hours >= 6 and duration_hours < 7:
        duration_score = 80
    elif duration_hours > 9 and duration_hours <= 10:
        duration_score = 85
    elif duration_hours >= 5 and duration_hours < 6:
        duration_score = 60
    elif duration_hours > 10:
        duration_score = 70
    else:
        duration_score = max(0, duration_hours / 5 * 40)
    
    # Quality score (normalized to 100)
    quality_score = quality * 10
    
    # Combined score
    return min(100, (duration_score * 0.5) + (quality_score * 0.5))


def analyze_sleep_logs(logs: list[SleepLog]) -> dict:
    """
    Analyze multiple sleep logs for patterns and statistics.
    
    Args:
        logs: List of sleep logs
    
    Returns:
        Dictionary with sleep analysis
    """
    if not logs:
        return {
            "avg_duration_hours": 0,
            "avg_quality": 0,
            "avg_sleep_score": 0,
            "total_nights": 0,
            "nights_meeting_goal": 0,
            "goal_achievement_rate": 0
        }
    
    durations = []
    qualities = []
    scores = []
    nights_meeting_goal = 0
    
    for log in logs:
        duration = calculate_sleep_duration_hours(log.sleep_start, log.sleep_end)
        durations.append(duration)
        qualities.append(log.sleep_quality)
        scores.append(calculate_sleep_score(duration, log.sleep_quality))
        
        if duration >= 7 and duration <= 9:
            nights_meeting_goal += 1
    
    return {
        "avg_duration_hours": round(sum(durations) / len(durations), 1),
        "avg_quality": round(sum(qualities) / len(qualities), 1),
        "avg_sleep_score": round(sum(scores) / len(scores), 1),
        "total_nights": len(logs),
        "nights_meeting_goal": nights_meeting_goal,
        "goal_achievement_rate": round(nights_meeting_goal / len(logs) * 100, 1)
    }


# =============================================================================
# Sleep-Blood Pressure Correlation
# =============================================================================

def analyze_sleep_bp_correlation(sleep_logs: list[SleepLog]) -> dict:
    """
    Analyze correlation between sleep patterns and blood pressure risk.
    
    Poor sleep is strongly correlated with elevated blood pressure:
    - Less than 6 hours: 20-30% increased hypertension risk
    - 6-7 hours: Elevated systolic BP (+5-10 mmHg)
    - Poor quality: Disrupted autonomic nervous system
    
    Args:
        sleep_logs: List of recent sleep logs
    
    Returns:
        Dictionary with correlation analysis and warnings
    """
    if not sleep_logs:
        return {
            "avg_hours": 0,
            "avg_quality": 0,
            "warnings": [],
            "bp_risk_level": RiskLevel.LOW
        }
    
    # Calculate averages
    total_hours = 0
    total_quality = 0
    
    for log in sleep_logs:
        duration = calculate_sleep_duration_hours(log.sleep_start, log.sleep_end)
        total_hours += duration
        total_quality += log.sleep_quality
    
    avg_hours = total_hours / len(sleep_logs)
    avg_quality = total_quality / len(sleep_logs)
    
    warnings: list[HealthWarning] = []
    
    # Check for sleep deprivation
    if avg_hours < 6:
        warnings.append(HealthWarning(
            type="danger",
            message="Severe Sleep Deprivation",
            detail=f"Averaging {avg_hours:.1f} hours. Less than 6 hours of sleep "
                   "significantly increases blood pressure and cortisol levels. "
                   "Risk of hypertension elevated by 20-30%."
        ))
    elif avg_hours < 7:
        warnings.append(HealthWarning(
            type="warning",
            message="Insufficient Sleep",
            detail=f"Averaging {avg_hours:.1f} hours. Studies show 7-9 hours is "
                   "optimal. Chronic short sleep is linked to elevated systolic BP "
                   "(+5-10 mmHg)."
        ))
    
    # Check for poor sleep quality
    if avg_quality < 5:
        warnings.append(HealthWarning(
            type="danger",
            message="Poor Sleep Quality",
            detail=f"Quality score: {avg_quality:.1f}/10. Poor sleep quality disrupts "
                   "your autonomic nervous system, increasing cortisol and adrenaline "
                   "which raises blood pressure."
        ))
    elif avg_quality < 7:
        warnings.append(HealthWarning(
            type="warning",
            message="Below Optimal Sleep Quality",
            detail=f"Quality score: {avg_quality:.1f}/10. Aim for 7+ quality score. "
                   "Fragmented sleep prevents adequate BP dipping during rest."
        ))
    
    # Check for excessive sleep
    if avg_hours > 9:
        warnings.append(HealthWarning(
            type="info",
            message="Excessive Sleep Duration",
            detail=f"Averaging {avg_hours:.1f} hours. Sleeping more than 9 hours "
                   "regularly may indicate underlying health issues and is associated "
                   "with increased cardiovascular risk."
        ))
    
    # Determine risk level
    if avg_hours < 6 or avg_quality < 5:
        bp_risk_level = RiskLevel.HIGH
    elif avg_hours < 7 or avg_quality < 7:
        bp_risk_level = RiskLevel.MODERATE
    else:
        bp_risk_level = RiskLevel.LOW
    
    return {
        "avg_hours": round(avg_hours, 1),
        "avg_quality": round(avg_quality, 1),
        "warnings": warnings,
        "bp_risk_level": bp_risk_level
    }


# =============================================================================
# Workout Calculations
# =============================================================================

def analyze_workout_stats(workouts: list[Workout]) -> dict:
    """
    Analyze workout statistics.
    
    Args:
        workouts: List of workout records
    
    Returns:
        Dictionary with workout statistics
    """
    if not workouts:
        return {
            "total_workouts": 0,
            "total_duration_min": 0,
            "total_calories": 0,
            "avg_duration_min": 0,
            "avg_calories": 0,
            "workouts_by_type": {}
        }
    
    total_duration = sum(w.duration_min for w in workouts)
    total_calories = sum(w.calories_burned for w in workouts)
    
    # Group by type
    workouts_by_type: dict[str, int] = {}
    for workout in workouts:
        workouts_by_type[workout.workout_type] = workouts_by_type.get(workout.workout_type, 0) + 1
    
    return {
        "total_workouts": len(workouts),
        "total_duration_min": total_duration,
        "total_calories": total_calories,
        "avg_duration_min": round(total_duration / len(workouts), 1),
        "avg_calories": round(total_calories / len(workouts), 1),
        "workouts_by_type": workouts_by_type
    }


def calculate_workout_score(workouts_per_week: int, avg_duration_min: float) -> float:
    """
    Calculate workout score (0-100).
    
    Factors:
    - Frequency: 60% weight (optimal is 5 workouts per week)
    - Duration: 40% weight (optimal is 45 minutes per session)
    
    Args:
        workouts_per_week: Number of workouts in a week
        avg_duration_min: Average workout duration in minutes
    
    Returns:
        Workout score (0-100)
    """
    # Frequency score (optimal is 5 per week)
    frequency_score = min(100, (workouts_per_week / 5) * 100)
    
    # Duration score (optimal is 45 minutes)
    if avg_duration_min >= 30 and avg_duration_min <= 60:
        duration_score = 100
    elif avg_duration_min >= 20:
        duration_score = 80
    elif avg_duration_min > 60:
        duration_score = 90
    else:
        duration_score = max(0, (avg_duration_min / 30) * 60)
    
    return min(100, (frequency_score * 0.6) + (duration_score * 0.4))


# =============================================================================
# Nutrition Calculations
# =============================================================================

def calculate_nutrition_score(avg_meals: float, avg_water: float) -> float:
    """
    Calculate nutrition score (0-100).
    
    Factors:
    - Meal frequency: 50% weight (optimal is 3 meals per day)
    - Hydration: 50% weight (optimal is 8 glasses per day)
    
    Args:
        avg_meals: Average meals per day
        avg_water: Average glasses of water per day
    
    Returns:
        Nutrition score (0-100)
    """
    meals_score = min(100, (avg_meals / 3) * 100)
    water_score = min(100, (avg_water / 8) * 100)
    
    return (meals_score * 0.5) + (water_score * 0.5)


def analyze_nutrition_logs(logs: list[NutritionLog]) -> dict:
    """
    Analyze nutrition logs for patterns.
    
    Args:
        logs: List of nutrition logs
    
    Returns:
        Dictionary with nutrition analysis
    """
    if not logs:
        return {
            "avg_meals": 0,
            "avg_calories": 0,
            "avg_protein": 0,
            "avg_water": 0,
            "nutrition_score": 0
        }
    
    avg_meals = sum(log.meals for log in logs) / len(logs)
    avg_calories = sum(log.calories for log in logs) / len(logs)
    avg_protein = sum(log.protein for log in logs) / len(logs)
    avg_water = sum(log.water for log in logs) / len(logs)
    
    return {
        "avg_meals": round(avg_meals, 1),
        "avg_calories": round(avg_calories, 0),
        "avg_protein": round(avg_protein, 1),
        "avg_water": round(avg_water, 1),
        "nutrition_score": round(calculate_nutrition_score(avg_meals, avg_water), 1)
    }


