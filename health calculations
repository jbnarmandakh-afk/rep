def calculate_wellness_scores(
    sleep_logs: list[SleepLog],
    workouts: list[Workout],
    nutrition_logs: list[NutritionLog]
) -> dict:
    """
    Calculate comprehensive wellness scores including dopamine and cortisol levels.
    
    Dopamine (positive neurotransmitter) increases when:
    - Sleep goals are met
    - Regular exercise is maintained
    - Nutrition is balanced
    
    Cortisol (stress hormone) increases when:
    - Sleep is insufficient
    - Exercise is lacking
    - Nutrition is poor
    
    Args:
        sleep_logs: Recent sleep logs
        workouts: Recent workout records
        nutrition_logs: Recent nutrition logs
    
    Returns:
        Dictionary with wellness scores and hormone level estimates
    """
    # Calculate individual scores
    sleep_analysis = analyze_sleep_logs(sleep_logs)
    sleep_score = sleep_analysis["avg_sleep_score"] if sleep_logs else 0
    
    workout_stats = analyze_workout_stats(workouts)
    workout_days = workout_stats["total_workouts"]
    avg_duration = workout_stats["avg_duration_min"] if workouts else 0
    workout_score = calculate_workout_score(workout_days, avg_duration)
    
    nutrition_analysis = analyze_nutrition_logs(nutrition_logs)
    nutrition_score = nutrition_analysis["nutrition_score"]
    
    # Calculate dopamine level (positive - based on meeting goals)
    # Higher when all metrics are good
    dopamine_level = round(
        (sleep_score * 0.35) + 
        (workout_score * 0.35) + 
        (nutrition_score * 0.30)
    )
    
    # Calculate cortisol level (stress - inverse of wellness)
    # Higher when metrics are poor
    cortisol_level = round(
        100 - (
            (sleep_score * 0.40) + 
            (workout_score * 0.35) + 
            (nutrition_score * 0.25)
        )
    )
    
    # Ensure values are within bounds
    dopamine_level = max(0, min(100, dopamine_level))
    cortisol_level = max(0, min(100, cortisol_level))
    
    return {
        "sleep_score": round(sleep_score, 1),
        "workout_score": round(workout_score, 1),
        "nutrition_score": round(nutrition_score, 1),
        "dopamine_level": dopamine_level,
        "cortisol_level": cortisol_level,
        "avg_sleep_hours": sleep_analysis["avg_duration_hours"],
        "avg_sleep_quality": sleep_analysis["avg_quality"],
        "workout_days": workout_days,
        "avg_workout_duration": round(avg_duration, 1),
        "overall_wellness": round((dopamine_level + (100 - cortisol_level)) / 2, 1)
    }


def get_wellness_status(dopamine: int, cortisol: int) -> str:
    """
    Get overall wellness status based on dopamine/cortisol balance.
    
    Args:
        dopamine: Dopamine level (0-100)
        cortisol: Cortisol level (0-100)
    
    Returns:
        Wellness status description
    """
    balance = dopamine - cortisol
    
    if balance >= 40:
        return "Excellent - You're thriving!"
    elif balance >= 20:
        return "Good - Maintaining healthy balance"
    elif balance >= 0:
        return "Fair - Room for improvement"
    elif balance >= -20:
        return "Stressed - Consider lifestyle adjustments"
    else:
        return "High Stress - Immediate attention recommended"


def generate_wellness_recommendations(wellness_scores: dict) -> list[str]:
    """
    Generate personalized wellness recommendations.
    
    Args:
        wellness_scores: Dictionary from calculate_wellness_scores
    
    Returns:
        List of recommendation strings
    """
    recommendations = []
    
    # Sleep recommendations
    if wellness_scores["sleep_score"] < 60:
        recommendations.append(
            "Prioritize sleep: Aim for 7-9 hours nightly. Consider a consistent "
            "bedtime routine and limiting screen time before bed."
        )
    elif wellness_scores["sleep_score"] < 80:
        recommendations.append(
            "Improve sleep quality: Your duration may be okay, but focus on "
            "sleep environment (dark, cool, quiet) for better quality."
        )
    
    # Workout recommendations
    if wellness_scores["workout_score"] < 40:
        recommendations.append(
            "Increase physical activity: Start with 20-30 minute walks daily. "
            "Even light exercise significantly reduces cortisol."
        )
    elif wellness_scores["workout_score"] < 70:
        recommendations.append(
            "Add variety to workouts: Mix cardio with strength training for "
            "optimal stress reduction and dopamine boost."
        )
    
    # Nutrition recommendations
    if wellness_scores["nutrition_score"] < 50:
        recommendations.append(
            "Focus on nutrition basics: Eat 3 balanced meals and drink at least "
            "8 glasses of water daily. Dehydration increases cortisol."
        )
    elif wellness_scores["nutrition_score"] < 75:
        recommendations.append(
            "Optimize hydration: You're eating well but may need more water. "
            "Proper hydration supports mood and energy levels."
        )
    
    # Cortisol-specific recommendations
    if wellness_scores["cortisol_level"] > 60:
        recommendations.append(
            "High cortisol detected: Consider stress management techniques like "
            "meditation, deep breathing, or yoga. Chronic stress affects all health metrics."
        )
    
    # Positive reinforcement
    if wellness_scores["dopamine_level"] >= 70:
        recommendations.append(
            "Great job! You're maintaining healthy habits. Keep up the consistency "
            "for long-term wellbeing."
        )
    
    return recommendations if recommendations else ["You're doing well! Maintain your current healthy habits."]


