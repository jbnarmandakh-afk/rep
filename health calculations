def get_summary_stats(
    bp_logs: list[BloodPressureLog],
    sleep_logs: list[SleepLog],
    workouts: list[Workout],
    health_metrics: list[HealthMetric]
) -> dict:
    """
    Get comprehensive summary statistics for dashboard display.
    
    Args:
        bp_logs: Blood pressure logs
        sleep_logs: Sleep logs
        workouts: Workout records
        health_metrics: Health metric logs
    
    Returns:
        Dictionary with summary statistics
    """
    # Latest BP reading
    latest_bp = bp_logs[0] if bp_logs else None
    bp_analysis = analyze_blood_pressure_trends(bp_logs[:7])
    
    # Sleep analysis
    sleep_analysis = analyze_sleep_logs(sleep_logs[:7])
    
    # Workout stats
    workout_stats = analyze_workout_stats(workouts[:7])
    
    # Latest weight
    weight_metrics = [m for m in health_metrics if m.metric_type == "weight"]
    latest_weight = weight_metrics[0].value if weight_metrics else None
    
    return {
        "blood_pressure": {
            "latest_systolic": latest_bp.systolic if latest_bp else None,
            "latest_diastolic": latest_bp.diastolic if latest_bp else None,
            "latest_heart_rate": latest_bp.heart_rate if latest_bp else None,
            "category": bp_analysis["category"].value,
            "trend": bp_analysis["trend"]
        },
        "sleep": {
            "avg_hours": sleep_analysis["avg_duration_hours"],
            "avg_quality": sleep_analysis["avg_quality"],
            "goal_rate": sleep_analysis["goal_achievement_rate"]
        },
        "workouts": {
            "this_week": workout_stats["total_workouts"],
            "total_calories": workout_stats["total_calories"],
            "avg_duration": workout_stats["avg_duration_min"]
        },
        "weight": latest_weight
    }


